# =========================================================================
# CareerMate Environment Variables Template
# Copy this file to '.env' on your server and update the values.
# =========================================================================

# Gemini API Key for AI service
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configurations (defaults match docker-compose.yml)
POSTGRES_DB=careermate_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Ports (if you want to customize them)
GATEWAY_PORT=8080
FRONTEND_PORT=80
